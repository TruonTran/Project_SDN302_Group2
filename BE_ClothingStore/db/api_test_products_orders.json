{
  "_comment": "Test API Product + Admin search orders. baseUrl đổi nếu PORT khác. Lấy token: POST /api/auth/login (admin: isAdmin true). Nhét vào headers Authorization: Bearer <accessToken>",
  "baseUrl": "http://localhost:8000",
  "variables": {
    "categoryId_sample": "67cddf7234dd98846323bf7f",
    "productId_active": "67cde24b34dd98846323bfaa",
    "productId_inactive": "67cde13534dd98846323bf97",
    "userId_sample": "67d3273853148c78e247ab84",
